{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "sunreye-stack",
      "components": ["server", "web", "addon"]
    }
  ],
  "packages": {
    ".": {
      "component": "server",
      "release-type": "node",
      "exclude-paths": ["apps/web", "apps/docs", "packages/inverter-core", "packages/profile-sdk", "sunreye"]
    },
    "apps/web": {
      "component": "web",
      "release-type": "node"
    },
    "packages/inverter-core": {
      "component": "inverter-core",
      "release-type": "node"
    },
    "packages/profile-sdk": {
      "component": "profile-sdk",
      "release-type": "node"
    },
    "sunreye": {
      "component": "addon",
      "release-type": "simple"
    }
  }
}
