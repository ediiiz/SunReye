# ── SunReye deployment config ────────────────────────────────────────────────
# Copy to `.env` and adjust. This file is used two ways by docker compose:
#   • ${VAR} interpolation inside docker-compose.yml
#   • injected into the `server` container via env_file
# Never commit the filled-in .env.

# ── Image / ports ────────────────────────────────────────────────────────────
# Release tag to run. "latest" tracks the default branch; pin to e.g. v1.2.3.
SUNREYE_TAG=latest
WEB_PORT=3001
SERVER_PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Used both for the Postgres container and the server's DATABASE_URL.
POSTGRES_PASSWORD=change-me

# ── Auth (required) ──────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 48   (must be >= 32 chars)
BETTER_AUTH_SECRET=
# Public URL the server is reached at.
BETTER_AUTH_URL=http://localhost:3000
# Origin allowed to call the server (your web app's public URL).
CORS_ORIGIN=http://localhost:3001

# ── Inverter ─────────────────────────────────────────────────────────────────
# Leave INVERTER_SIMULATE=true to run with a fake inverter (no hardware).
INVERTER_SIMULATE=true
INVERTER_PROFILE=deye-sunsynk
INVERTER_HOST=192.168.1.100
INVERTER_PORT=502
INVERTER_UNIT_ID=1
POLL_INTERVAL_MS=1000

# ── Public API (optional) ────────────────────────────────────────────────────
# Comma-separated keys for /api/v1. Empty fails closed in production.
API_KEYS=

# ── MQTT bridge (optional) ───────────────────────────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=sunreye
# MQTT_USERNAME=
# MQTT_PASSWORD=

# ── Home Assistant discovery (optional, requires MQTT_ENABLED=true) ──────────
HA_DISCOVERY_ENABLED=false
HA_DISCOVERY_PREFIX=homeassistant

# ── Logging (optional) ───────────────────────────────────────────────────────
# LOG_LEVEL=info
