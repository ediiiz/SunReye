{
  "$schema": "https://docs.fallow.tools/schema.json",
  "ignorePatterns": [
    "apps/web/src/lib/components/ui/**",
    "apps/web/src/lib/hooks/**",
    "apps/web/src/lib/utils.ts",
    "packages/backend/data/**"
  ],
  "ignoreDependencies": [
    "bits-ui",
    "tailwind-variants",
    "svelte-sonner",
    "mode-watcher",
    "@internationalized/date",
    "phosphor-svelte",
    "sharp",
    "clsx",
    "tailwind-merge",
    "zod"
  ],
  "dynamicallyLoaded": ["apps/docs/src/styles/theme.css"],
  "usedClassMembers": [{ "implements": "InverterSource", "members": ["read"] }],
  "rules": {
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn"
  },
  "health": {
    "thresholdOverrides": [
      {
        "files": ["packages/inverter-core/**", "packages/inverter-deye-sg05lp3/**"],
        "maxCyclomatic": 15,
        "maxCognitive": 20,
        "maxCrap": 200,
        "reason": "WIP inverter integration scaffold; CRAP scores are inflated estimates while test coverage is absent. Tighten once these modules stabilize and are covered."
      },
      {
        "files": [
          "apps/web/src/routes/(app)/**",
          "apps/web/src/routes/setup/**",
          "apps/web/src/lib/components/inverter/**",
          "apps/web/src/lib/components/settings/**",
          "apps/web/src/lib/components/setup/**",
          "apps/web/src/lib/components/app-sidebar.svelte",
          "apps/web/src/lib/inverter/**",
          "apps/web/src/lib/cost/**",
          "apps/web/src/components/**"
        ],
        "maxCyclomatic": 25,
        "maxCognitive": 30,
        "maxCrap": 700,
        "reason": "Manifest-driven dashboard UI: high CRAP is inflated by presentational template branching over the metric catalog with no unit-test coverage. Tighten once the render layer stabilizes and is covered."
      },
      {
        "files": ["apps/server/src/**"],
        "maxCrap": 120,
        "reason": "CRAP is estimated without coverage data; the DB-bound modules (cost, energy, inverter routes) have no unit coverage yet, so small functions with cyclomatic 5-9 estimate above the default 30. Tighten once coverage reporting is wired into fallow."
      }
    ]
  }
}
