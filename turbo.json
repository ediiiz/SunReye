{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "DATABASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        ".svelte-kit/**",
        "build/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "dependsOn": [
        "//#db:start"
      ],
      "cache": false,
      "persistent": true
    },
    "preview": {
      "dependsOn": [
        "build",
        "//#db:start"
      ],
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "dependsOn": [
        "//#db:start"
      ],
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "dependsOn": [
        "//#db:start"
      ],
      "cache": false
    },
    "db:timescale": {
      "dependsOn": [
        "db:push"
      ],
      "cache": false
    },
    "db:studio": {
      "dependsOn": [
        "//#db:start"
      ],
      "cache": false,
      "persistent": true
    },
    "//#db:start": {
      "cache": false
    },
    "//#db:stop": {
      "cache": false
    },
    "//#db:watch": {
      "dependsOn": [
        "//#db:start"
      ],
      "cache": false,
      "persistent": true
    },
    "//#db:down": {
      "cache": false
    }
  }
}