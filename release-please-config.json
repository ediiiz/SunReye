{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "packages": {
    ".": {
      "component": "server",
      "release-type": "node",
      "exclude-paths": ["apps/web", "apps/docs", "packages/profile-sdk"]
    },
    "apps/web": {
      "component": "web",
      "release-type": "node"
    },
    "packages/profile-sdk": {
      "component": "profile-sdk",
      "release-type": "node"
    }
  }
}
