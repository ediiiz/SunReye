{
  "name": "SunReye",
  "version": "0.2.2",
  "license": "AGPL-3.0-only",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.22",
      "@better-auth/api-key": "1.6.22"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev db:watch db:studio",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "preview": "turbo run db:push db:timescale -F @SunReye/db && turbo run preview -F web -F server",
    "db:push": "turbo run db:push -F @SunReye/db",
    "db:studio": "turbo run db:studio -F @SunReye/db",
    "db:generate": "turbo run db:generate -F @SunReye/db",
    "db:migrate": "turbo run db:migrate -F @SunReye/db",
    "db:timescale": "turbo run db:timescale -F @SunReye/db",
    "db:start": "docker compose -f docker-compose.db.yml up -d --wait",
    "db:watch": "docker compose -f docker-compose.db.yml logs -f",
    "db:stop": "docker compose -f docker-compose.db.yml stop",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "bun test apps/*/src packages/*/src",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text --coverage-dir=coverage apps/*/src packages/*/src",
    "coverage:badge": "bun run scripts/coverage-badge.mjs coverage/lcov.info coverage/coverage.svg",
    "check": "oxlint && oxfmt --write",
    "sync:brand": "node scripts/sync-brand.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@SunReye/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@SunReye/config": "workspace:*",
    "@types/bun": "catalog:",
    "fallow": "^2.104.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint",
      "oxfmt --write"
    ],
    "**/*.svelte": [
      "oxlint"
    ],
    "**/*.{ts,tsx,js,jsx,svelte,json,jsonc}": [
      "sh -c 'bunx fallow audit --gate new-only --quiet'"
    ]
  },
  "packageManager": "bun@1.3.13",
  "patchedDependencies": {
    "svelte@5.56.4": "patches/svelte@5.56.4.patch"
  }
}
