{
  "$schema": "https://docs.fallow.tools/schema.json",
  "ignorePatterns": [
    "apps/web/src/lib/components/ui/**",
    "apps/web/src/lib/utils.ts",
    "packages/backend/data/**"
  ],
  "ignoreDependencies": [
    "bits-ui",
    "tailwind-variants",
    "@convex/_generated",
    "svelte-sonner",
    "mode-watcher",
    "@internationalized/date",
    "phosphor-svelte"
  ],
  "rules": {
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn"
  },
  "health": {
    "thresholdOverrides": [
      {
        "files": [
          "packages/inverter-core/**",
          "packages/inverter-deye-sunsynk/**",
          "apps/web/src/routes/dashboard/+page.svelte"
        ],
        "maxCyclomatic": 15,
        "maxCognitive": 20,
        "maxCrap": 200,
        "reason": "WIP inverter integration scaffold; CRAP scores are inflated estimates while test coverage is absent. Tighten once these modules stabilize and are covered."
      }
    ]
  }
}
